apiVersion: v1
kind: Secret
metadata:
  name: dreamteams-deploy-repo
  namespace: {{ argocd_namespace }}
  labels:
    argocd.argoproj.io/secret-type: repository
type: Opaque
stringData:
  type: git
  url: {{ deploy_repo | to_json }}
{% if deploy_repo is match('^(git@|ssh://)') %}
  sshPrivateKey: |
{{ (deploy_repo_ssh_private_key | default(ssh_private_key)) | indent(4, true) }}
  insecure: "true"
{% endif %}
