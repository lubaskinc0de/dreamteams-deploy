{
  "annotations": { "list": [] },
  "description": "DreamTeams business event counters — registrations, competitions, applications, forms, avatars.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [
    {
      "asDropdown": false,
      "icon": "external link",
      "includeVars": true,
      "keepTime": true,
      "tags": ["dreamteams"],
      "targetBlank": false,
      "title": "DreamTeams Dashboards",
      "type": "dashboards"
    }
  ],
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Total Registrations",
      "description": "All-time user registrations across all roles",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(dreamteams_registrations_total{role=~\"$role\"})",
          "instant": true,
          "legendFormat": "__auto",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "blue", "mode": "fixed" },
          "unit": "short",
          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] }
        },
        "overrides": []
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Competitions Created",
      "description": "All-time total competitions created",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(dreamteams_competitions_created_total)",
          "instant": true,
          "legendFormat": "__auto",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "purple", "mode": "fixed" },
          "unit": "short",
          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "purple", "value": null }] }
        },
        "overrides": []
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Applications Submitted",
      "description": "All-time total competition applications submitted",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(dreamteams_applications_submitted_total)",
          "instant": true,
          "legendFormat": "__auto",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "light-blue", "mode": "fixed" },
          "unit": "short",
          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "light-blue", "value": null }] }
        },
        "overrides": []
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Acceptance Rate",
      "description": "Share of submitted applications that were accepted",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(dreamteams_applications_accepted_total) / clamp_min(sum(dreamteams_applications_submitted_total), 1) * 100",
          "instant": true,
          "legendFormat": "__auto",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "unit": "percent",
          "decimals": 1,
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 20 },
              { "color": "green", "value": 50 }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Registration Rate by Role",
      "description": "New registrations per second, split by role (participant vs organizer)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (role) (rate(dreamteams_registrations_total{role=~\"$role\"}[$__rate_interval]))",
          "legendFormat": "{{role}}",
          "refId": "A"
        }
      ],
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max", "lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 15,
            "gradientMode": "opacity",
            "showPoints": "never",
            "spanNulls": false,
            "stacking": { "group": "A", "mode": "normal" }
          },
          "unit": "reqps",
          "mappings": []
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "participant" },
            "properties": [{ "id": "color", "value": { "fixedColor": "#56a64b", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "organizer" },
            "properties": [{ "id": "color", "value": { "fixedColor": "#5195ce", "mode": "fixed" } }]
          }
        ]
      }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Application Activity",
      "description": "Application lifecycle rates: submitted, accepted, rejected, withdrawn per second",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(dreamteams_applications_submitted_total[$__rate_interval])",
          "legendFormat": "submitted",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(dreamteams_applications_accepted_total[$__rate_interval])",
          "legendFormat": "accepted",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(dreamteams_applications_rejected_total[$__rate_interval])",
          "legendFormat": "rejected",
          "refId": "C"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(dreamteams_applications_withdrawn_total[$__rate_interval])",
          "legendFormat": "withdrawn",
          "refId": "D"
        }
      ],
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max", "lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "gradientMode": "opacity",
            "showPoints": "never",
            "spanNulls": false
          },
          "unit": "reqps",
          "mappings": []
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "submitted" },
            "properties": [{ "id": "color", "value": { "fixedColor": "#5195ce", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "accepted" },
            "properties": [{ "id": "color", "value": { "fixedColor": "#37872d", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "rejected" },
            "properties": [{ "id": "color", "value": { "fixedColor": "#e62f2f", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "withdrawn" },
            "properties": [{ "id": "color", "value": { "fixedColor": "#8e8e8e", "mode": "fixed" } }]
          }
        ]
      }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Competition Creation Rate",
      "description": "New competitions created per second",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(dreamteams_competitions_created_total[$__rate_interval])",
          "legendFormat": "competitions",
          "refId": "A"
        }
      ],
      "options": {
        "tooltip": { "mode": "single", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "bottom", "calcs": [] }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "purple", "mode": "fixed" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 20,
            "gradientMode": "opacity",
            "showPoints": "never",
            "spanNulls": false
          },
          "unit": "reqps",
          "mappings": []
        },
        "overrides": []
      }
    },
