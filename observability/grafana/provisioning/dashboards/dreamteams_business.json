  "refresh": "1m",
  "templating": {
    "list": [
      {
        "allValue": ".*",
        "current": {},
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "definition": "label_values(dreamteams_registrations_total, role)",
        "hide": 0,
        "includeAll": true,
        "label": "Role",
        "multi": true,
        "name": "role",
        "options": [],
        "query": {
          "query": "label_values(dreamteams_registrations_total, role)",
          "refId": "StandardVariableQuery"
        },
        "refresh": 2,
        "regex": "",
        "sort": 1,
        "type": "query"
      }
    ]
  },
  "schemaVersion": 40,
  "tags": ["dreamteams", "business"],
  "time": { "from": "now-24h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
