{
  "annotations": { "list": [] },
  "description": "DreamTeams log analytics — severity distribution, volume over time, and per-logger breakdown.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [
    {
      "asDropdown": false,
      "icon": "external link",
      "includeVars": true,
      "keepTime": true,
      "tags": ["dreamteams"],
      "targetBlank": false,
      "title": "DreamTeams Dashboards",
      "type": "dashboards"
    }
  ],
  "panels": [
    {
      "id": 1,
      "type": "piechart",
      "title": "Severity Distribution",
      "description": "Share of each log level in the selected time window and containers.",
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "sum by(level) (count_over_time({container_name=~\"$log_scope\", container_name=~\"$container\", level=~\"$level\"} !~ \"/internal/(alive|ready)\" !~ \"otel-collector\\\\.observability:4318\" | json | trace_id=~\"$trace_id\" | user_id=~\"$user_id\" |~ \"(?i)$search\" [$__range]))",
          "queryType": "instant",
          "refId": "A"
        }
      ],
      "options": {
        "displayLabels": ["value", "name"],
        "pieType": "pie",
        "legend": { "displayMode": "list", "placement": "right", "showLegend": true, "values": ["percent"] },
        "tooltip": { "mode": "single", "sort": "desc" }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic-by-name" },
          "mappings": []
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "error" }, "properties": [{ "id": "color", "value": { "fixedColor": "#e62f2f", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "warning" }, "properties": [{ "id": "color", "value": { "fixedColor": "#fa6400", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "info" }, "properties": [{ "id": "color", "value": { "fixedColor": "#5195ce", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "debug" }, "properties": [{ "id": "color", "value": { "fixedColor": "#8e8e8e", "mode": "fixed" } }] }
        ]
      },
      "transformations": [
        { "id": "organize", "options": { "excludeByName": { "Time": true }, "renameByName": { "Value #A": "count", "level": "label" } } },
        { "id": "rowsToFields", "options": { "mappings": [{ "fieldName": "label", "handlerKey": "field.name" }, { "fieldName": "count", "handlerKey": "field.value" }] } }
      ]
    },
    {
      "id": 2,
      "type": "bargauge",
      "title": "Count by Level",
      "description": "Absolute log count per severity level in the selected range.",
      "gridPos": { "h": 8, "w": 6, "x": 6, "y": 0 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "sum by(level) (count_over_time({container_name=~\"$log_scope\", container_name=~\"$container\", level=~\"$level\"} !~ \"/internal/(alive|ready)\" !~ \"otel-collector\\\\.observability:4318\" | json | trace_id=~\"$trace_id\" | user_id=~\"$user_id\" |~ \"(?i)$search\" [$__range]))",
          "queryType": "instant",
          "refId": "A"
        }
      ],
      "options": {
        "displayMode": "lcd",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": true },
        "showUnfilled": true,
        "valueMode": "color"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic-by-name" },
          "unit": "short",
          "mappings": []
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "error" }, "properties": [{ "id": "color", "value": { "fixedColor": "#e62f2f", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "warning" }, "properties": [{ "id": "color", "value": { "fixedColor": "#fa6400", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "info" }, "properties": [{ "id": "color", "value": { "fixedColor": "#5195ce", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "debug" }, "properties": [{ "id": "color", "value": { "fixedColor": "#8e8e8e", "mode": "fixed" } }] }
        ]
      },
      "transformations": [
        { "id": "organize", "options": { "excludeByName": { "Time": true }, "renameByName": { "Value #A": "count", "level": "label" } } },
        { "id": "rowsToFields", "options": { "mappings": [{ "fieldName": "label", "handlerKey": "field.name" }, { "fieldName": "count", "handlerKey": "field.value" }] } }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Log Volume by Level",
      "description": "Log lines per second broken down by severity. Stacked — total height shows overall throughput.",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "sum by(level) (count_over_time({container_name=~\"$log_scope\", container_name=~\"$container\", level=~\"$level\"} !~ \"/internal/(alive|ready)\" !~ \"otel-collector\\\\.observability:4318\" | json | trace_id=~\"$trace_id\" | user_id=~\"$user_id\" |~ \"(?i)$search\" [$__interval]))",
          "queryType": "range",
          "legendFormat": "{{level}}",
          "refId": "A"
        }
      ],
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "bars",
            "barAlignment": 0,
            "barWidthFactor": 1,
            "lineWidth": 0,
            "fillOpacity": 100,
            "gradientMode": "none",
            "showPoints": "never",
            "spanNulls": false,
            "stacking": { "group": "A", "mode": "normal" }
          },
          "unit": "short",
          "mappings": []
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "error" }, "properties": [{ "id": "color", "value": { "fixedColor": "#e62f2f", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "warning" }, "properties": [{ "id": "color", "value": { "fixedColor": "#fa6400", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "info" }, "properties": [{ "id": "color", "value": { "fixedColor": "#5195ce", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "debug" }, "properties": [{ "id": "color", "value": { "fixedColor": "#8e8e8e", "mode": "fixed" } }] }
        ]
      }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Error & Warning Rate",
      "description": "Error and warning log lines per second. Spikes indicate application problems worth investigating.",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "sum(count_over_time({container_name=~\"$log_scope\", container_name=~\"$container\", level=\"error\"} !~ \"/internal/(alive|ready)\" !~ \"otel-collector\\\\.observability:4318\" | json | trace_id=~\"$trace_id\" | user_id=~\"$user_id\" |~ \"(?i)$search\" [$__interval]))",
          "queryType": "range",
          "legendFormat": "error",
          "refId": "A"
        },
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "sum(count_over_time({container_name=~\"$log_scope\", container_name=~\"$container\", level=\"warning\"} !~ \"/internal/(alive|ready)\" !~ \"otel-collector\\\\.observability:4318\" | json | trace_id=~\"$trace_id\" | user_id=~\"$user_id\" |~ \"(?i)$search\" [$__interval]))",
          "queryType": "range",
          "legendFormat": "warning",
          "refId": "B"
        }
      ],
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max", "lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 15,
            "gradientMode": "opacity",
            "showPoints": "never",
            "spanNulls": false
          },
          "unit": "short",
          "mappings": []
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "error" }, "properties": [{ "id": "color", "value": { "fixedColor": "#e62f2f", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "warning" }, "properties": [{ "id": "color", "value": { "fixedColor": "#fa6400", "mode": "fixed" } }] }
        ]
      }
    },
    {
      "id": 5,
      "type": "table",
      "title": "Top Loggers",
      "description": "Which application modules emit the most log lines in the selected window.",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "topk(20, sum by(logger) (count_over_time({container_name=~\"$log_scope\", container_name=~\"$container\", level=~\"$level\"} !~ \"/internal/(alive|ready)\" !~ \"otel-collector\\\\.observability:4318\" | json | trace_id=~\"$trace_id\" | user_id=~\"$user_id\" |~ \"(?i)$search\" [$__range])))",
          "queryType": "instant",
          "refId": "A"
        }
      ],
      "options": {
        "sortBy": [{ "desc": true, "displayName": "Value" }],
        "footer": { "show": false }
      },
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "mappings": [] },
        "overrides": [
          { "matcher": { "id": "byName", "options": "logger" }, "properties": [{ "id": "displayName", "value": "Logger" }, { "id": "custom.width", "value": 360 }] },
          { "matcher": { "id": "byName", "options": "Value" }, "properties": [{ "id": "displayName", "value": "Log Lines" }, { "id": "custom.displayMode", "value": "lcd-gauge" }, { "id": "color", "value": { "fixedColor": "#5195ce", "mode": "fixed" } }] }
        ]
      },
      "transformations": [
        { "id": "organize", "options": { "excludeByName": { "Time": true } } }
      ]
    },
    {
      "id": 6,
      "type": "logs",
      "title": "Log Stream",
      "description": "Filtered log lines. Click any trace_id to open the distributed trace in Tempo.",
      "gridPos": { "h": 18, "w": 24, "x": 0, "y": 16 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "{container_name=~\"$log_scope\", container_name=~\"$container\", level=~\"$level\"} !~ \"/internal/(alive|ready)\" !~ \"otel-collector\\\\.observability:4318\" | json | trace_id=~\"$trace_id\" | user_id=~\"$user_id\" |~ \"(?i)$search\"",
          "direction": "backward",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": false,
        "showCommonLabels": false,
        "wrapLogMessage": false,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "enableInfiniteScrolling": false,
        "sortOrder": "Descending",
        "dedupStrategy": "none"
      },
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "trace_id" },
            "properties": [
              {
                "id": "links",
                "value": [
                  {
                    "title": "Open in Tempo",
                    "url": "/explore?orgId=1&left={\"datasource\":\"tempo\",\"queries\":[{\"refId\":\"A\",\"queryType\":\"traceId\",\"query\":\"${__value.raw}\"}],\"range\":{\"from\":\"now-1h\",\"to\":\"now\"}}",
                    "targetBlank": false
                  }
                ]
              }
            ]
          }
        ]
      }
    }
  ],
  "refresh": "30s",
  "schemaVersion": 41,
  "tags": ["dreamteams", "logs"],
  "templating": {
    "list": [
      {
        "current": { "text": "Business services", "value": "api|exporter-api|exporter-worker" },
        "hide": 0,
        "label": "Scope",
        "name": "log_scope",
        "options": [
          { "selected": true, "text": "Business services", "value": "api|exporter-api|exporter-worker" },
          { "selected": false, "text": "All containers", "value": ".+" }
        ],
        "query": "Business services : api|exporter-api|exporter-worker, All containers : .+",
        "skipUrlSync": false,
        "type": "custom"
      },
      {
        "allValue": ".+",
        "allowCustomValue": false,
        "current": { "text": "All", "value": "$__all" },
        "datasource": { "type": "loki", "uid": "loki" },
        "definition": "",
        "hide": 0,
        "includeAll": true,
        "label": "Container",
        "multi": true,
        "name": "container",
        "options": [],
        "query": {
          "label": "container_name",
          "refId": "LokiVariableQueryEditor-VariableQuery",
          "stream": "",
          "type": 1
        },
        "refresh": 1,
        "regex": "",
