        "query": "",
        "skipUrlSync": false,
        "type": "textbox"
      }
    ]
  },
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "DreamTeams — Log Analytics",
  "uid": "dreamteams-logs-analytics",
  "version": 1
}
