{
  "annotations": { "list": [] },
  "description": "DreamTeams structured log stream with filters for container, level, trace ID, user ID, and full-text search.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [
    {
      "asDropdown": false,
      "icon": "external link",
      "includeVars": true,
      "keepTime": true,
      "tags": ["dreamteams"],
      "targetBlank": false,
      "title": "DreamTeams Dashboards",
      "type": "dashboards"
    }
  ],
  "panels": [
    {
      "id": 1,
      "type": "logs",
      "title": "Log Stream",
      "description": "Structured JSON logs. Click any trace_id to open the full distributed trace in Tempo.",
      "gridPos": { "h": 24, "w": 24, "x": 0, "y": 0 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "{container_name=~\"$container\", level=~\"$level\"} !~ \"/internal/(alive|ready)\" | json | trace_id=~\"$trace_id\" | user_id=~\"$user_id\" |~ \"(?i)$search\"",
          "direction": "backward",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": false,
        "showCommonLabels": false,
        "wrapLogMessage": false,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "enableInfiniteScrolling": false,
        "sortOrder": "Descending",
        "dedupStrategy": "none"
      },
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "trace_id" },
            "properties": [
              {
                "id": "links",
                "value": [
                  {
                    "title": "Open in Tempo",
                    "url": "/explore?orgId=1&left={\"datasource\":\"tempo\",\"queries\":[{\"refId\":\"A\",\"queryType\":\"traceId\",\"query\":\"${__value.raw}\"}],\"range\":{\"from\":\"now-1h\",\"to\":\"now\"}}",
                    "targetBlank": false
                  }
                ]
              }
            ]
          }
        ]
      }
    }
  ],
  "refresh": "30s",
